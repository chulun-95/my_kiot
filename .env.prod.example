# ============================================================
# .env.prod — Production (GIAI ĐOẠN 1, 1 VPS Hetzner)
# ------------------------------------------------------------
# Copy file này thành .env.prod TRÊN SERVER, điền giá trị thật.
# KHÔNG commit .env.prod (đã nằm trong .gitignore).
# Sinh secret:  openssl rand -hex 32
# ============================================================

# --- PostgreSQL (api ↔ db qua service name 'db' trong compose) ---
POSTGRES_USER=pos_user
POSTGRES_PASSWORD=CHANGE_ME_mat_khau_manh_32_ky_tu
POSTGRES_DB=pos_db
DATABASE_URL=postgresql+asyncpg://pos_user:CHANGE_ME_mat_khau_manh_32_ky_tu@db:5432/pos_db

# --- App ---
APP_ENV=production
JWT_SECRET_KEY=CHANGE_ME_64_ky_tu_random          # openssl rand -hex 32
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
JWT_REFRESH_TOKEN_EXPIRE_DAYS=30
BCRYPT_ROUNDS=12

# QUAN TRỌNG: production chạy HTTPS → cookie refresh token phải Secure
COOKIE_SECURE=true

# Same-origin (FE + BE chung domain qua Nginx) nên CORS gần như không cần.
# Để domain thật cho chắc:
CORS_ORIGINS=https://my-kiot.timxe-namdinh.com

# --- R2 ảnh sản phẩm — GIAI ĐOẠN 1 CHƯA DÙNG, để trống ---
# Khi cần upload ảnh thì bỏ comment + điền key (R2 vẫn free tier 10GB):
# R2_ACCOUNT_ID=
# R2_ACCESS_KEY=
# R2_SECRET_KEY=
# R2_BUCKET=pos-images
